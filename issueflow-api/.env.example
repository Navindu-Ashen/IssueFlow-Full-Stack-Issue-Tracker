# Server
NODE_ENV=production
PORT=3001

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_strong_access_token_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_strong_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=7d

# OTP / Password Reset
OTP_EXPIRY_MINUTES=10
RESET_TOKEN_EXPIRY_MINUTES=15

# Uploads
CLOUDINARY_UPLOAD_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_FOLDER=issueflow
IMAGE_UPLOAD_MAX_SIZE_BYTES=5242880
